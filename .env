# EmailJS credentials
# Crie uma conta em https://www.emailjs.com/
# 1. Crie um Service (e-mail conectado) e copie o Service ID
# 2. Crie um Template com as variáveis: {{from_name}}, {{from_email}}, {{subject}}, {{message}}
#    e configure o destinatário como vgsantos.dev@gmail.com
# 3. Copie a Public Key em Account > API Keys

VITE_EMAILJS_SERVICE_ID=your_service_id
VITE_EMAILJS_TEMPLATE_ID=your_template_id
VITE_EMAILJS_PUBLIC_KEY=your_public_key
